<Window x:Class="KataevWPF.KataevPartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Редактирование партнера — Катаев" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Данные партнера" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"
                   Foreground="#333"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="KataevNameBox" Margin="5" Height="25"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип партнера:" VerticalAlignment="Center" Margin="0,5"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="KataevTypeBox" Margin="5" Height="25">
                    <ComboBoxItem Content="Оптовый покупатель" IsSelected="True"/>
                    <ComboBoxItem Content="Розничный магазин"/>
                    <ComboBoxItem Content="Интернет-магазин"/>
                    <ComboBoxItem Content="Дистрибьютор"/>
                    <ComboBoxItem Content="Сервисный центр"/>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Рейтинг (0+):" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="KataevRatingBox" Margin="5" Height="25" PreviewTextInput="KataevRatingBox_PreviewTextInput"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="ИНН:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="KataevInnBox" Margin="5" Height="25"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Адрес:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="KataevAddressBox" Margin="5" Height="25"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Фамилия дир.:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="KataevDirLastBox" Margin="5" Height="25"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Имя дир.:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="KataevDirFirstBox" Margin="5" Height="25"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Отчество дир.:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="7" Grid.Column="1" x:Name="KataevDirMidBox" Margin="5" Height="25"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="8" Grid.Column="1" x:Name="KataevPhoneBox" Margin="5" Height="25"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Email:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="9" Grid.Column="1" x:Name="KataevEmailBox" Margin="5" Height="25"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="KataevSaveButton_Click" Margin="0,0,10,0"/>
            <Button Content="Отмена" Width="100" Height="35" 
                    Background="#F44336" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="KataevCancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>