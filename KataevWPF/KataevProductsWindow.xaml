<Window x:Class="KataevWPF.KataevProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление продукцией — Катаев"
        Height="520" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F9F9F9">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Продукция" 
                   FontSize="20" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,12" 
                   Foreground="#1976D2"/>

        <DataGrid Grid.Row="1" x:Name="ProductsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"          Binding="{Binding Id}"      Width="60"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}"    Width="*"/>
                <DataGridTextColumn Header="Артикул"     Binding="{Binding Article}" Width="140"/>
                <DataGridTextColumn Header="Тип"         Binding="{Binding Type}"    Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="➕ Добавить"      Width="120" Margin="4" Click="BtnAdd_Click"   Style="{StaticResource ActionButton}"/>
            <Button Content="✏️ Редактировать" Width="120" Margin="4" Click="BtnEdit_Click"  x:Name="BtnEdit"  IsEnabled="False" Style="{StaticResource ActionButton}" Background="#FF9800"/>
            <Button Content="🗑️ Удалить"      Width="120" Margin="4" Click="BtnDelete_Click" x:Name="BtnDelete" IsEnabled="False" Style="{StaticResource ActionButton}" Background="#F44336"/>
            <Button Content="Закрыть"          Width="120" Margin="4,4,0,4" Click="BtnClose_Click" Style="{StaticResource ToolbarButton}" Background="#757575"/>
        </StackPanel>
    </Grid>
</Window>