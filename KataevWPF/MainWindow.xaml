<Window x:Class="KataevWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KataevWPF"
        mc:Ignorable="d"
        Title="Kataev — Система управления партнерами"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F9F9F9"
        Loaded="KataevWindow_Loaded">
    <Window.Resources>
        <DataTemplate x:Key="PartnerListItemTemplate">
            <Border x:Name="CardBorder" Background="White" CornerRadius="6" BorderThickness="1" BorderBrush="#E0E0E0" Margin="4">
                <Grid>
                    <Rectangle x:Name="AccentBar" Width="5" HorizontalAlignment="Left" Fill="#1976D2" RadiusX="6" RadiusY="6" Visibility="Collapsed"/>
                    <StackPanel Margin="12,10,12,10">
                        <TextBlock x:Name="TxtName" Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#1A237E" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding PartnerType}" FontSize="12" Foreground="#555" FontStyle="Italic" Margin="0,2,0,4"/>
                        <TextBlock FontSize="12.5" Foreground="#1976F3" Margin="0,0,0,8">
                            <Run Text="Рейтинг: "/><Run Text="{Binding Rating}"/>
                        </TextBlock>
                        <Button Content="➕ Добавить заказ" Style="{StaticResource ActionButton}" Padding="12,6" FontSize="13" HorizontalAlignment="Left"
                                Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BoolToVis}}"
                                Click="PartnerCardAddOrder_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="CardBorder" Property="Background" Value="#E8F4FD"/>
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#2196F3"/>
                    <Setter TargetName="CardBorder" Property="BorderThickness" Value="1.5"/>
                    <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="TxtName" Property="Foreground" Value="#0D47A1"/>
                    <Setter TargetName="TxtName" Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1976D2" Padding="15,10" CornerRadius="4">
            <TextBlock Text="Система управления партнерами" Foreground="White" FontSize="18" FontWeight="Bold"/>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="White" Margin="0,5,0,5">
            <Button Content="➕ Добавить партнера" Style="{StaticResource ToolbarButton}" Click="KataevAddButton_Click"/>
            <Button Content="✏️ Редактировать партнера" Style="{StaticResource ToolbarButton}" Click="KataevEditButton_Click" x:Name="BtnEditPartner" IsEnabled="False"/>
            <Button Content="🗑️ Удалить партнера" Style="{StaticResource ToolbarButton}" Background="#F44336" Click="KataevDeleteButton_Click" x:Name="BtnDeletePartner" IsEnabled="False"/>
            <Button Content="📦 Управление продукцией" Style="{StaticResource ToolbarButton}" Click="BtnManageProducts_Click"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10" Background="#F5F5F5">
                        <TextBlock Text="Список партнеров" FontWeight="Bold"/>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="KataevPartnersList"
                             ItemTemplate="{StaticResource PartnerListItemTemplate}"
                             SelectionChanged="KataevPartnersList_SelectionChanged"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F5FAFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#EEE"/>

            <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid x:Name="DetailsPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#E3F2FD" Padding="15" Margin="10,10,10,5" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Партнер:" FontWeight="Bold" Foreground="#555" FontSize="12"/>
                                    <TextBlock x:Name="LblPartnerName" Text="" FontSize="16" FontWeight="Bold" Foreground="#1976D2"/>
                                    <TextBlock x:Name="LblPartnerType" Text="" FontSize="12" FontStyle="Italic"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="Текущая скидка:" FontWeight="Bold" Foreground="#555" FontSize="12"/>
                                    <Border x:Name="BadgeDiscount" Padding="8,4" CornerRadius="12" Background="Gray" HorizontalAlignment="Right">
                                        <TextBlock x:Name="LblDiscount" Text="0%" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,5,0,0">
                                    <TextBlock Text="Контакты:" FontWeight="Bold" Foreground="#555" FontSize="12"/>
                                    <TextBlock x:Name="LblPhone" Text="" FontSize="13"/>
                                    <TextBlock x:Name="LblEmail" Text="" FontSize="13"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,5,0,0" HorizontalAlignment="Right">
                                    <TextBlock Text="Общий объем продаж:" FontWeight="Bold" Foreground="#555" FontSize="12"/>
                                    <TextBlock x:Name="LblTotalVolume" Text="0 ед." FontSize="14" FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,5,0,0" Orientation="Horizontal">
                                    <TextBlock Text="Адрес:" FontWeight="Bold" Foreground="#555" FontSize="12" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="LblAddress" Text="" FontSize="13" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,5,10,5" HorizontalAlignment="Left">
                            <TextBlock Text="История продаж (Заказы):" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button Content="➕ Добавить заказ" Style="{StaticResource ActionButton}" Click="BtnAddOrder_Click" x:Name="BtnAddOrder"/>
                            <Button Content="✏️ Изменить заказ" Style="{StaticResource ActionButton}" Background="#FF9800" Click="BtnEditOrder_Click" x:Name="BtnEditOrder" IsEnabled="False"/>
                            <Button Content="🗑️ Удалить заказ" Style="{StaticResource ActionButton}" Background="#F44336" Click="BtnDeleteOrder_Click" x:Name="BtnDeleteOrder" IsEnabled="False"/>
                        </StackPanel>

                        <DataGrid Grid.Row="2" x:Name="OrdersGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="White"
                                  BorderBrush="#DDD"
                                  BorderThickness="0,1,0,0"
                                  SelectionChanged="OrdersGrid_SelectionChanged"
                                  Margin="10,0,10,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата продажи" Binding="{Binding SaleDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                                <DataGridTextColumn Header="Продукция" Binding="{Binding KataevProduct.Name}" Width="*"/>
                                <DataGridTextColumn Header="Артикул" Binding="{Binding KataevProduct.Article}" Width="80"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding KataevProduct.Type}" Width="80"/>
                                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <TextBlock x:Name="PlaceholderText"
                               Text="Выберите партнера из списка слева, чтобы просмотреть информацию и управлять заказами."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="16" Foreground="#999" TextAlignment="Center" TextWrapping="Wrap" Margin="20"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#333" Padding="10,5" CornerRadius="4">
            <Grid>
                <TextBlock x:Name="KataevPartnersCountText" Text="Партнеров: 0" Foreground="#AAA" HorizontalAlignment="Right" Margin="0,0,20,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>